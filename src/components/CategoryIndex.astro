---
import Base from '../layouts/Base.astro';
import ArticleCard from './ArticleCard.astro';
import { CATEGORIES, type CategoryKey } from '../consts';
import { getCollection, type CollectionEntry } from 'astro:content';

interface Props { category: CategoryKey; }
const { category } = Astro.props;
const cat = CATEGORIES[category];

const entries = await getCollection(category as any, ({ data }: any) => !data.draft);
entries.sort((a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title={`${cat.name}｜張現傑`} description={cat.subtitle}>
  <section class="cat-hero">
    <div class="container">
      <div class="cat-hero__eyebrow" style={`color:${cat.color};`}>{cat.name.toUpperCase ? cat.name : cat.name}</div>
      <h1 class="cat-hero__title" style={`color:${cat.color};`}>{cat.name}</h1>
      <p class="cat-hero__sub">{cat.subtitle}</p>
      <p class="cat-hero__desc">{cat.description}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {entries.length === 0 ? (
        <p class="center muted">此分類文章準備中。</p>
      ) : (
        <div class="cards">
          {entries.map((e: any) => (
            <ArticleCard
              href={`/${category}/${e.slug}/`}
              title={e.data.title}
              excerpt={e.data.excerpt}
              date={e.data.date}
              category={category}
              coverImage={e.data.coverImage}
            />
          ))}
        </div>
      )}
    </div>
  </section>
</Base>
