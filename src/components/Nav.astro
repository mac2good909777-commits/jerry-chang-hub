---
import { NAV_ITEMS, SITE } from '../consts';

interface Props { translucent?: boolean; }
const { translucent = false } = Astro.props;
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isCurrent = (href: string) => {
  const h = href.replace(/\/$/, '') || '/';
  if (h === '/') return pathname === '/';
  return pathname === h || pathname.startsWith(h + '/');
};
---
<header class="nav" data-translucent={translucent ? 'true' : 'false'}>
  <div class="container nav__inner">
    <a class="nav__brand" href="/" aria-label={SITE.author + ' 首頁'}>
      {SITE.author}<span class="nav__brand-sub">工業不動產</span>
    </a>
    <nav class="nav__links" aria-label="主要導覽">
      {NAV_ITEMS.map(item => (
        <a class="nav__link" href={item.href} data-current={isCurrent(item.href)}>{item.label}</a>
      ))}
    </nav>
    <button class="nav__hamburger" type="button" aria-label="開啟選單" aria-expanded="false" data-toggle="nav">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/></svg>
    </button>
  </div>
  <div class="nav__mobile" data-open="false">
    {NAV_ITEMS.map(item => (
      <a href={item.href}>{item.label}</a>
    ))}
  </div>
</header>

<script is:inline>
  (function(){
    var btn = document.querySelector('[data-toggle="nav"]');
    var panel = document.querySelector('.nav__mobile');
    if (!btn || !panel) return;
    btn.addEventListener('click', function(){
      var open = panel.getAttribute('data-open') === 'true';
      panel.setAttribute('data-open', String(!open));
      btn.setAttribute('aria-expanded', String(!open));
    });
  })();
</script>
