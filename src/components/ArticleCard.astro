---
import { CATEGORIES, type CategoryKey } from '../consts';

interface Props {
  href: string;
  title: string;
  excerpt: string;
  date: Date;
  category: CategoryKey;
  coverImage?: string;
}
const { href, title, excerpt, date, category, coverImage } = Astro.props;
const cat = CATEGORIES[category];
const dateStr = date.toISOString().slice(0, 10);
---
<a class="card" href={href} aria-label={title}>
  <div class="card__cover" style={coverImage ? `background-image:url(${coverImage});background-size:cover;background-position:center;` : `background: linear-gradient(135deg, ${cat.color}, ${category === 'insights' ? '#F59E0B' : '#2B5A8C'});`}>
    {!coverImage && <span>{cat.name}</span>}
  </div>
  <div class="card__body">
    <div class="card__meta">
      <span class="card__tag" style={`background:${cat.colorSoft};color:${cat.color};`}>{cat.name}</span>
      <span>{dateStr}</span>
    </div>
    <div class="card__title">{title}</div>
    <div class="card__excerpt">{excerpt}</div>
  </div>
</a>
