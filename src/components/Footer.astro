---
import { SITE, NAV_ITEMS } from '../consts';
import VersionSwitch from './VersionSwitch.astro';
const year = new Date().getFullYear();
const buildDate = new Date().toISOString().slice(0, 10);
---
<footer class="footer">
  <div class="container footer__row">
    <div>
      <div>© {year} {SITE.author}. {SITE.licenseNo}</div>
      <div class="mt-8" style="margin-top:4px;">可整合協作：瑞禾開發（依專案邀請）。最後更新：{buildDate}</div>
    </div>
    <div class="footer__links">
      {NAV_ITEMS.map(item => (<a href={item.href}>{item.label}</a>))}
    </div>
  </div>
</footer>

<VersionSwitch current="v1" />
