---
import { CATEGORIES, type CategoryKey } from '../../consts';

interface Props {
  href: string;
  title: string;
  excerpt: string;
  date: Date;
  category: CategoryKey;
  coverImage?: string;
}
const { href, title, excerpt, date, category, coverImage } = Astro.props;
const cat = CATEGORIES[category];
const dateStr = date.toISOString().slice(0, 10).replace(/-/g, '.');
const mediaClass = category === 'industry-data' ? 'v2-insight__media--industry'
  : category === 'market-view' ? 'v2-insight__media--market'
  : 'v2-insight__media--insights';
---
<a class="v2-insight" href={href} aria-label={title}>
  <div class={`v2-insight__media ${mediaClass}`} style={coverImage ? `background-image:url(${coverImage});background-size:cover;background-position:center;` : ''}>
    {!coverImage && <span class="v2-insight__media-label">{cat.name}</span>}
  </div>
  <div class="v2-insight__meta">
    <span class="v2-insight__category">{cat.name}</span>
    <span>·</span>
    <span>{dateStr}</span>
  </div>
  <h3 class="v2-insight__title">{title}</h3>
  <p class="v2-insight__excerpt">{excerpt}</p>
</a>
