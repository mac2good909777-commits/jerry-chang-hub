---
import V2Base from '../../layouts/V2Base.astro';
import { SITE } from '../../consts';
---
<V2Base title={`聯繫｜${SITE.author}`} description="LINE、電話、Email 聯繫方式與 vCard 下載。">
  <section class="v2-cat-hero">
    <div class="v2-wrap v2-cat-hero__inner">
      <div class="v2-cat-hero__kicker">CONTACT</div>
      <h1 class="v2-cat-hero__title">聯繫我</h1>
      <p class="v2-cat-hero__desc">若您或身邊朋友有工業不動產相關需求，歡迎直接聯繫。{SITE.workHours}。</p>
    </div>
  </section>

  <section class="v2-section">
    <div class="v2-wrap">
      <div style="display:grid;grid-template-columns:1.2fr 1fr;gap:64px;align-items:start;">
        <div>
          <div class="v2-section__kicker">CHANNELS</div>
          <h2 style="font-size:clamp(22px,2.4vw,32px);margin-bottom:32px;">聯繫方式</h2>
          <div style="display:flex;flex-direction:column;gap:0;">
            <a href={SITE.contact.line} style="display:flex;justify-content:space-between;align-items:center;padding:28px 0;border-bottom:1px solid var(--v2-line);color:var(--v2-ink);">
              <div>
                <div style="font-family:'Noto Serif TC',serif;font-size:20px;font-weight:500;margin-bottom:4px;">LINE（主要）</div>
                <div style="color:var(--v2-text-soft);font-size:14px;">看到訊息會在上班時段內回覆</div>
              </div>
              <span style="color:var(--v2-gold);font-size:20px;">→</span>
            </a>
            <a href={`tel:${SITE.contact.phone}`} style="display:flex;justify-content:space-between;align-items:center;padding:28px 0;border-bottom:1px solid var(--v2-line);color:var(--v2-ink);">
              <div>
                <div style="font-family:'Noto Serif TC',serif;font-size:20px;font-weight:500;margin-bottom:4px;">電話</div>
                <div style="color:var(--v2-text-soft);font-size:14px;">{SITE.contact.phone}</div>
              </div>
              <span style="color:var(--v2-gold);font-size:20px;">→</span>
            </a>
            <a href={`mailto:${SITE.contact.email}`} style="display:flex;justify-content:space-between;align-items:center;padding:28px 0;border-bottom:1px solid var(--v2-line);color:var(--v2-ink);">
              <div>
                <div style="font-family:'Noto Serif TC',serif;font-size:20px;font-weight:500;margin-bottom:4px;">Email</div>
                <div style="color:var(--v2-text-soft);font-size:14px;">{SITE.contact.email}</div>
              </div>
              <span style="color:var(--v2-gold);font-size:20px;">→</span>
            </a>
            <a href="/images/chang.vcf" download style="display:flex;justify-content:space-between;align-items:center;padding:28px 0;border-bottom:1px solid var(--v2-line);color:var(--v2-ink);">
              <div>
                <div style="font-family:'Noto Serif TC',serif;font-size:20px;font-weight:500;margin-bottom:4px;">vCard 下載</div>
                <div style="color:var(--v2-text-soft);font-size:14px;">一鍵存入通訊錄</div>
              </div>
              <span style="color:var(--v2-gold);font-size:20px;">↓</span>
            </a>
            <a href={SITE.contact.fbPage} style="display:flex;justify-content:space-between;align-items:center;padding:28px 0;color:var(--v2-ink);">
              <div>
                <div style="font-family:'Noto Serif TC',serif;font-size:20px;font-weight:500;margin-bottom:4px;">Facebook</div>
                <div style="color:var(--v2-text-soft);font-size:14px;">粉絲頁「工業地產筆記」</div>
              </div>
              <span style="color:var(--v2-gold);font-size:20px;">→</span>
            </a>
          </div>
          <p style="margin-top:48px;font-size:14px;color:var(--v2-text-soft);line-height:1.85;">
            主要受理工業不動產相關諮詢 — 物件買賣、設廠選址、資產活化、交易風險初判。若為住商、租屋或其他類型不動產，可協助轉介合適的朋友。
          </p>
        </div>
        <div style="background:var(--v2-bg-cream);padding:48px 36px;text-align:center;">
          <div class="v2-section__kicker" style="justify-content:center;display:inline-flex;">QR CODE</div>
          <div style="width:220px;height:220px;margin:20px auto;border:2px dashed var(--v2-line);display:flex;align-items:center;justify-content:center;color:var(--v2-text-soft);font-size:13px;background:#fff;">
            LINE QR Code<br/>(/public/images/line-qr.png)
          </div>
          <div style="font-family:'Noto Serif TC',serif;font-size:20px;color:var(--v2-ink);margin-top:16px;">{SITE.author}</div>
          <div style="color:var(--v2-text-soft);font-size:13px;margin-top:4px;">{SITE.tagline}</div>
        </div>
      </div>
    </div>
  </section>
</V2Base>
