---
import V2Article from '../../../layouts/V2Article.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('market-view', ({ data }) => !data.draft);
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props as { entry: any };
const { Content } = await entry.render();
const d = entry.data;
---
<V2Article
  title={d.title}
  date={d.date}
  tags={d.tags}
  category="market-view"
  excerpt={d.excerpt}
  coverImage={d.coverImage}
  sourceNote={d.sourceNote}
  slug={entry.slug}
>
  <Content />
</V2Article>
