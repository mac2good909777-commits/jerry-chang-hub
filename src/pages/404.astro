---
import V4Base from '../layouts/V4Base.astro';
---
<V4Base title="頁面不存在｜張現傑 × 睦聚地產">
  <section class="v2-section" style="text-align:center;">
    <div class="v2-wrap--read">
      <div class="v2-section__kicker" style="justify-content:center;">404</div>
      <h1 class="v2-section__title" style="margin-left:auto;margin-right:auto;">頁面不存在</h1>
      <p style="color:var(--v2-text-soft);margin-bottom:32px;">
        你要找的頁面可能已移動或不存在。
      </p>
      <a class="v2-btn v2-btn--primary" href="/">回首頁 <span class="v2-btn__arrow">→</span></a>
    </div>
  </section>
</V4Base>
