---
import Base from '../layouts/Base.astro';
---
<Base title="頁面不存在｜張現傑">
  <section class="section center">
    <div class="container">
      <div class="cat-hero__eyebrow" style="color: var(--c-blue);">404</div>
      <h1 style="font-size:40px;">頁面不存在</h1>
      <p class="muted mb-24">你要找的頁面可能已移動或不存在。</p>
      <a class="btn btn--primary" href="/">回首頁</a>
    </div>
  </section>
</Base>
