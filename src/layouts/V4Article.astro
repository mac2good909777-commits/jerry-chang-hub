---
import V4Base from './V4Base.astro';
import V4Insight from '../components/v4/V4Insight.astro';
import { CATEGORIES, type CategoryKey } from '../consts';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  date: Date;
  tags: string[];
  category: CategoryKey;
  excerpt: string;
  coverImage?: string;
  sourceNote?: string;
  slug: string;
}
const { title, date, tags, category, excerpt, coverImage, sourceNote, slug } = Astro.props;
const cat = CATEGORIES[category];
const dateStr = date.toISOString().slice(0, 10).replace(/-/g, '.');

const related = (await getCollection(category as any, ({ data, slug: s }: any) => !data.draft && s !== slug))
  .sort((a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---
<V4Base title={`${title}｜張現傑 × 睦聚地產`} description={excerpt} image={coverImage}>
  <section class="v2-article-hero">
    <div class="v2-wrap">
      <nav class="v2-article-hero__crumb">
        <a href="/">首頁</a> · <a href={`/v4/${category}/`}>{cat.name}</a> · <span>{title}</span>
      </nav>
      <div class="v2-article-hero__meta">
        <span class="v2-article-hero__category">{cat.name}</span>
        <span>·</span>
        <span>{dateStr}</span>
        {tags.length > 0 && <>
          <span>·</span>
          <span>{tags.map(t => `#${t}`).join('  ')}</span>
        </>}
      </div>
      <h1 class="v2-article-hero__title">{title}</h1>
      <p class="v2-article-hero__excerpt">{excerpt}</p>
    </div>
  </section>

  <article class="v2-article-body">
    <div class="v2-wrap--read">
      {coverImage && (<img src={coverImage} alt={title} style="width:100%;margin-bottom:40px;" />)}
      <slot />
      {sourceNote && (
        <p style="margin-top:40px;padding:20px;background:var(--v2-bg-cream);color:var(--v2-text-soft);line-height:1.75;">{sourceNote}</p>
      )}
    </div>
  </article>

  {related.length > 0 && (
    <section class="v2-related">
      <div class="v2-wrap">
        <div class="v2-related__head">
          <div>
            <div class="v2-section__kicker">更多 {cat.name}</div>
            <h2 class="v2-related__title">相關內容</h2>
          </div>
          <a class="v2-btn v2-btn--ghost" href={`/v4/${category}/`}>看全部 <span class="v2-btn__arrow">→</span></a>
        </div>
        <div class="v2-insights">
          {related.map((r: any) => (
            <V4Insight
              href={`/v4/${category}/${r.slug}/`}
              title={r.data.title}
              excerpt={r.data.excerpt}
              date={r.data.date}
              category={category}
              coverImage={r.data.coverImage}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</V4Base>
