---
import Base from './Base.astro';
import AuthorBio from '../components/AuthorBio.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { CATEGORIES, type CategoryKey } from '../consts';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  date: Date;
  tags: string[];
  category: CategoryKey;
  excerpt: string;
  coverImage?: string;
  sourceNote?: string;
  slug: string;
}
const { title, date, tags, category, excerpt, coverImage, sourceNote, slug } = Astro.props;
const cat = CATEGORIES[category];
const dateStr = date.toISOString().slice(0, 10);

const related = (await getCollection(category as any, ({ data, slug: s }: any) => !data.draft && s !== slug))
  .sort((a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---
<Base title={`${title}｜張現傑`} description={excerpt} image={coverImage}>
  <article class="section">
    <div class="container-read">
      <nav class="crumb">
        <a href="/">首頁</a><span class="sep">›</span>
        <a href={`/${category}/`}>{cat.name}</a><span class="sep">›</span>
        <span>{title}</span>
      </nav>

      <h1 style="font-size:32px;line-height:1.35;color:var(--c-ink);margin-bottom:18px;">{title}</h1>

      <div class="article-meta">
        <span>{dateStr}</span>
        <span class="dot">·</span>
        <a href={`/${category}/`} class="card__tag" style={`background:${cat.colorSoft};color:${cat.color};text-decoration:none;`}>{cat.name}</a>
        {tags.length > 0 && (
          <>
            <span class="dot">·</span>
            {tags.map((t: string) => (<span class="muted">#{t}</span>))}
          </>
        )}
      </div>

      {coverImage && (
        <img src={coverImage} alt={title} style="width:100%;border-radius:12px;margin:20px 0;" />
      )}

      <div class="article-body">
        <slot />
      </div>

      <hr style="border:0;border-top:1px solid var(--c-gold);margin:40px 0 0;opacity:0.35;" />

      {sourceNote && (
        <p class="muted" style="font-size:13px;margin-top:16px;">{sourceNote}</p>
      )}

      <AuthorBio />

      {related.length > 0 && (
        <section class="mt-48">
          <h3 class="mb-16">相關文章</h3>
          <div class="cards">
            {related.map((r: any) => (
              <ArticleCard
                href={`/${category}/${r.slug}/`}
                title={r.data.title}
                excerpt={r.data.excerpt}
                date={r.data.date}
                category={category}
                coverImage={r.data.coverImage}
              />
            ))}
          </div>
        </section>
      )}
    </div>
  </article>
</Base>
